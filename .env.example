# Copy this file to .env and fill in your values.

# ── Email Credentials ──
# Use SENDER_EMAIL / SENDER_PASSWORD (or the older GMAIL_EMAIL / GMAIL_APP_PASSWORD)
SENDER_EMAIL=you@gmail.com
SENDER_PASSWORD=your_app_password

# ── SMTP Settings (optional — auto-detected from your email domain) ──
# Uncomment and set these ONLY if auto-detection doesn't work for your provider.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USE_TLS=false

# Common providers (auto-detected, no need to set):
#   Gmail:     smtp.gmail.com       port 465  SSL
#   Outlook:   smtp.office365.com   port 587  TLS
#   Yahoo:     smtp.mail.yahoo.com  port 465  SSL
#   Zoho:      smtp.zoho.com        port 465  SSL
#   Custom:    smtp.yourdomain.com  port 587  TLS

# ── Company ──
COMPANY_NAME=Company Name
EMAIL_SUBJECT=Offer Letter {role} Summer Internship | Company Name

# ── Parallelism ──
MAX_DOCX_WORKERS=4
MAX_EMAIL_WORKERS=4

# ── Paths / Misc ──
LOG_LEVEL=INFO
DATE_FORMAT=%d %B %Y
